# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used for magic-link email redirect and canonical URLs. Set to deployed URL in prod.
# e.g. https://stutigeet.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sentry (error tracking) ────────────────────────────────────────────────────
# Get from: https://sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
# Get from: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Upstash Redis (rate limiting) ──────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → REST API
# If unset, rate limiting is disabled (graceful fallback — safe for dev/preview).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics ──────────────────────────────────────────────────────────────────
# Plausible domain (the domain registered in your Plausible dashboard).
# If unset, analytics script is not injected.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stutigeet.com

# ── Public API ─────────────────────────────────────────────────────────────────
# Optional: comma-separated list of allowed origins for /api/v1/* CORS.
# If unset, the API is open to all origins (appropriate for a public read-only API).
# e.g. https://stutigeet.com,https://app.example.com
API_ALLOWED_ORIGINS=

# ── Feature flags ──────────────────────────────────────────────────────────────
# Set to "true" to enable the strict verification gate (refuse to render
# unverified lyrics older than site_settings.grace_days). Default: off.
STRICT_VERIFICATION_GATE=
